{
  "name": "code-ask",
  "version": "0.1.0",
  "description": "A CLI for indexing repositories and asking codebase questions.",
  "type": "module",
  "bin": {
    "code-ask": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "agent-skills"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
